## C1. SAS — Cohort with continuous enrollment & index date / SAS——连续参保与索引日期队列

```sas
/* First qualifying diagnosis = index date; require 6-mo continuous enrollment pre-index */
proc sql;
  create table index_dx as
  select patient_id, min(svc_date) as index_date format=date9.
  from claims_dx
  where dx_code in ('E1140','E1141')      /* disease code list */
  group by patient_id;
quit;

proc sql;
  create table cohort as
  select a.patient_id, a.index_date
  from index_dx a
  inner join enrollment e
    on a.patient_id = e.patient_id
   and e.enroll_start <= a.index_date - 180   /* 6-mo baseline covered */
   and e.enroll_end   >= a.index_date;
quit;
```
*Talking point / 讲解:* Baseline continuous enrollment lets me treat "no claim" as "no event," not "no data." / 基线连续参保让我把"无理赔"解读为"无事件"而非"无数据"。

## C2. SAS — Treatment-emergent AE flag / SAS——治疗期不良事件标志

```sas
data adae;
  merge ae adsl(keep=usubjid trtsdt trtedt);
  by usubjid;
  /* TEAE: onset on/after first dose (and within safety window of last dose) */
  if astdt >= trtsdt and (missing(trtedt) or astdt <= trtedt + 30) then trtemfl = 'Y';
  else trtemfl = 'N';
run;
```

## C3. SAS — Kaplan–Meier & Cox / SAS——KM 与 Cox

```sas
proc lifetest data=adtte plots=survival(atrisk cl);
  time aval*cnsr(1);            /* cnsr=1 censored, 0 event */
  strata trtp;                  /* log-rank across arms */
run;

proc phreg data=adtte;
  class trtp(ref='Placebo') / param=ref;
  model aval*cnsr(1) = trtp age sex ecog;   /* HR adjusted for covariates */
  hazardratio trtp;
  assess ph / resample;         /* check proportional hazards */
run;
```

## C4. SQL — Earliest event per patient, joined back to baseline / SQL——每患者最早事件并关联基线

```sql
WITH first_rx AS (
  SELECT patient_id, MIN(fill_date) AS index_date
  FROM pharmacy_claims
  WHERE ndc IN (SELECT ndc FROM drug_list)
  GROUP BY patient_id
)
SELECT f.patient_id, f.index_date, d.charlson_score, d.prior_hosp_flag
FROM first_rx f
LEFT JOIN baseline_covariates d
  ON f.patient_id = d.patient_id;
```
*Talking point / 讲解:* Grouped MIN gives time zero; the left join preserves every eligible patient. / 分组 MIN 得到时间零点；左连接保留每位合格患者。

## C5. R — Propensity score matching + balance check / R——倾向性评分匹配与均衡检查

```r
library(MatchIt); library(tableone)

# Estimate PS and match (nearest neighbor, caliper)
m <- matchit(treated ~ age + sex + charlson + prior_hosp,
             data = df, method = "nearest", caliper = 0.2)
matched <- match.data(m)

# Assess balance via standardized mean differences (target |SMD| < 0.1)
vars <- c("age","sex","charlson","prior_hosp")
tab  <- CreateTableOne(vars = vars, strata = "treated",
                       data = matched, test = FALSE)
print(tab, smd = TRUE)
```

## C6. R — IPTW with stabilized weights / R——稳定化 IPTW

```r
ps  <- glm(treated ~ age + sex + charlson, family = binomial, data = df)$fitted
p_t <- mean(df$treated)
df$sw <- ifelse(df$treated == 1, p_t/ps, (1 - p_t)/(1 - ps))   # stabilized weights

library(survival)
cox <- coxph(Surv(time, event) ~ treated, data = df, weights = sw,
             robust = TRUE)                                    # robust SE for weighting
summary(cox)
```

## C7. Python — QC automation (duplicates, missingness, count reconciliation) / Python——QC 自动化

```python
import pandas as pd

def qc_report(df, key):
    return {
        "n_rows": len(df),
        "n_unique_patients": df[key].nunique(),
        "n_duplicate_keys": df.duplicated(subset=key).sum(),
        "missing_pct": (df.isna().mean() * 100).round(1).to_dict(),
    }

report = qc_report(cohort, key="patient_id")
assert report["n_duplicate_keys"] == 0, "Unexpected duplicate patient keys"
```

